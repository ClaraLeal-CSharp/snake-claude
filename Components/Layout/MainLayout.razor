@inherits LayoutComponentBase

@Body

<div id="blazor-error-ui" data-nosnippet
     style="display:none; position:fixed; bottom:1rem; left:50%; transform:translateX(-50%);
            background:#0c1a11; border:1px solid #2a6640; color:#5aaf7a;
            font-family:monospace; font-size:0.75rem; padding:0.6rem 1rem;
            border-radius:4px; z-index:99999;">
    ⚠ erro —
    <a href="." style="color:#7ed4a0;">recarregar</a>
    <span class="dismiss" onclick="document.getElementById('blazor-error-ui').style.display='none'"
          style="cursor:pointer; margin-left:0.5rem; opacity:0.6;">✕</span>
</div>
